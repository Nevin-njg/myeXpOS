int main() {
  decl
    int x;
    str filename;
  enddecl

  begin
    breakpoint;
    x = exposcall("Read", -1, filename);
    x = exposcall("Exec", filename);

    breakpoint;
    if (x == -1) then
      filename = "NO_FILE";
      x = exposcall("Write", -1, filename);
    endif;
    return 0;
  end
}
