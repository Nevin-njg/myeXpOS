alias currPID R0;
currPID = [SYSTEM_STATUS_TABLE  + 1];

alias curr_process_table R1;
curr_process_table = PROCESS_TABLE + 16 * currPID; 

[curr_process_table + 4] = TERMINATED;

alias i R2;
alias state R3;

i = 1;
while(i < 16) do
  state = [PROCESS_TABLE + i * 16 + 4];
	if(state != TERMINATED) then
		call MOD_5;
	endif;
	i = i + 1;
endwhile;

halt;
