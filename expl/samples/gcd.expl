decl
  int gcd(int a, int b);
enddecl

int gcd(int a, int b) {
  decl
    int ret;
  enddecl
  begin
    if (a == 0) then
      ret = b;
    else
      ret = gcd((b % a), a);
    endif;

    return ret;
  end
}

int main() {
  decl
    int a, b, res, temp;
  enddecl
  begin
    temp = exposcall( "Read", -1, a );
    temp = exposcall( "Read", -1, b );
    res = gcd(a, b);
    temp = exposcall( "Write", -2, res );
    return 0;
  end
}
